---
import { siteConfig } from "../config";
import BrandIcon from "./BrandIcon.astro";
import { getIconInfo } from "../utils/icons";
---

<section id="hero" class="relative overflow-hidden" style={`background: linear-gradient(135deg, ${siteConfig.colors.surfaceLight} 0%, ${siteConfig.colors.surface} 50%, white 100%);`}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <!-- Text side -->
      <div class="flex-1 text-center md:text-left order-2 md:order-1">
        <h1 class="hero-title text-3xl sm:text-4xl md:text-5xl font-bold text-[var(--color-primary-dark)] leading-tight">
          {siteConfig.name}
        </h1>
        <p class="hero-subtitle mt-3 text-lg sm:text-xl text-[var(--color-primary)] font-medium" style="font-family: 'Source Sans 3', sans-serif;">
          {siteConfig.tagline}
        </p>

        <!-- Credential badges -->
        <div class="hero-badges mt-5 flex flex-wrap justify-center md:justify-start gap-2">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-[var(--color-primary-dark)] text-white" style="font-family: 'Space Grotesk', sans-serif;">
            {getIconInfo("cmp").file && <BrandIcon name="cmp" size={14} dark />}
            CMP {siteConfig.credentials.cmp}
          </span>
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-semibold bg-[var(--color-primary)] text-white" style="font-family: 'Space Grotesk', sans-serif;">
            RNE {siteConfig.credentials.rne}
          </span>
        </div>

        <!-- Society pills -->
        <div class="hero-badges mt-3 flex flex-wrap justify-center md:justify-start gap-2">
          {siteConfig.societies.map((s) => (
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-white border border-[var(--color-primary-light)]/30 text-[var(--color-primary-dark)]">
              {s.logo && getIconInfo(s.logo).file && <BrandIcon name={s.logo} size={14} />}
              {s.name}
            </span>
          ))}
        </div>

        <!-- CTA button -->
        <div class="hero-cta mt-7">
          <a
            href={`https://wa.me/${siteConfig.cta.phone.replace(/\+/g, '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[var(--color-primary)] text-white font-semibold text-sm btn-hover shadow-md"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492l4.624-1.464A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.813c-2.188 0-4.219-.596-5.975-1.634l-.428-.254-2.742.869.862-2.681-.278-.443A9.777 9.777 0 012.188 12c0-5.414 4.398-9.813 9.812-9.813S21.813 6.586 21.813 12 17.414 21.813 12 21.813z"/></svg>
            {siteConfig.cta.buttonText}
          </a>
        </div>
      </div>

      <!-- Profile photo -->
      <div class="flex-shrink-0 order-1 md:order-2 hero-photo">
        <div class="relative">
          <div class="w-40 h-40 md:w-52 md:h-52 rounded-2xl bg-gradient-to-br from-[var(--color-surface)] to-[var(--color-surface-light)] overflow-hidden shadow-2xl">
            <img
              src="/profile-v2.png"
              alt={`Dr. ${siteConfig.shortName}`}
              class="w-full h-full object-cover object-top"
              loading="eager"
            />
          </div>
          <!-- Decorative ring -->
          <div class="absolute -inset-3 rounded-2xl border-2 border-[var(--color-primary-light)]/20 -z-10"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="hero-stats border-t border-[var(--color-surface)]" style={`background: ${siteConfig.colors.primaryDark};`}>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5">
      <div class="grid grid-cols-3 gap-4 text-center">
        {siteConfig.stats.map((stat) => (
          <div>
            <div class="text-xl sm:text-2xl md:text-3xl font-bold text-white font-numbers" style="font-family: 'Space Grotesk', sans-serif;">
              {stat.value}
            </div>
            <div class="text-xs sm:text-sm text-blue-200 mt-0.5">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
