---
/**
 * Research & Recognition — Academic credibility section.
 * Shows publications, presentations, and professional recognition.
 */
import { siteConfig } from "../config";
import BrandIcon from "./BrandIcon.astro";
import { getIconInfo } from "../utils/icons";
---

<section id="investigacion" class="py-16 md:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-12 reveal">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[var(--color-primary-dark)]">
        Investigacion y Reconocimientos
      </h2>
      <div class="mt-3 w-16 h-1 mx-auto bar-shimmer rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Research publications -->
      <div class="reveal">
        <h3 class="text-sm font-semibold text-[var(--color-primary)] uppercase tracking-wider mb-5">
          Publicaciones Cientificas
        </h3>
        <div class="space-y-4">
          {siteConfig.research.map((pub, i) => (
            <div class={`card-hover bg-[var(--color-surface-light)] rounded-xl p-5 border border-[var(--color-surface)]`}>
              <div class="flex items-start justify-between gap-3 mb-2">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-[var(--color-primary)] text-white">
                  {pub.type}
                </span>
                <span class="text-xs font-semibold text-[var(--color-primary-dark)] font-numbers whitespace-nowrap" style="font-family: 'Space Grotesk', sans-serif;">
                  {pub.year}
                </span>
              </div>
              <h4 class="text-sm font-bold text-[var(--color-primary-dark)] mb-1 leading-snug">
                {pub.title}
              </h4>
              <p class="text-xs text-gray-500">{pub.venue}</p>
              {pub.id && (
                <p class="text-xs text-[var(--color-primary)] mt-1 font-numbers" style="font-family: 'Space Grotesk', sans-serif;">
                  ID: {pub.id}
                </p>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Recognitions -->
      <div class="reveal stagger-2">
        <h3 class="text-sm font-semibold text-[var(--color-primary)] uppercase tracking-wider mb-5">
          Reconocimientos
        </h3>
        <div class="space-y-4">
          {siteConfig.recognitions.map((rec) => (
            <div class="card-hover bg-[var(--color-surface-light)] rounded-xl p-5 border border-[var(--color-surface)]">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-8 h-8 rounded-full bg-[var(--color-surface)] flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-[var(--color-primary)]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </div>
                <span class="text-xs font-semibold text-[var(--color-primary-dark)] font-numbers" style="font-family: 'Space Grotesk', sans-serif;">
                  {rec.year}
                </span>
              </div>
              <h4 class="text-sm font-bold text-[var(--color-primary-dark)] mb-1">
                {rec.title}
              </h4>
              <p class="text-xs text-gray-500">{rec.institution}</p>
            </div>
          ))}
        </div>

        <!-- Societies -->
        <h3 class="text-sm font-semibold text-[var(--color-primary)] uppercase tracking-wider mt-8 mb-5">
          Sociedades Cientificas
        </h3>
        <div class="space-y-3">
          {siteConfig.societies.map((soc) => (
            <div class="flex items-center gap-3 p-3 rounded-lg bg-[var(--color-surface-light)] border border-[var(--color-surface)]">
              <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center flex-shrink-0 overflow-hidden p-1">
                {soc.logo && getIconInfo(soc.logo).file ? (
                  <BrandIcon name={soc.logo} size={28} />
                ) : (
                  <span class="text-xs font-bold text-[var(--color-primary-dark)]" style="font-family: 'Space Grotesk', sans-serif;">
                    {soc.name.slice(0, 3)}
                  </span>
                )}
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-[var(--color-primary-dark)] truncate">
                  {soc.fullName}
                </p>
                {soc.id && (
                  <p class="text-xs text-gray-500 font-numbers" style="font-family: 'Space Grotesk', sans-serif;">
                    ID: {soc.id}
                  </p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
