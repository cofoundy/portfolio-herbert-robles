---
import { siteConfig } from "../config";
---

<footer class="py-8" style={`background: ${siteConfig.colors.primaryDark};`}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col items-center text-center gap-4">
      <!-- Name -->
      <p class="text-white font-semibold text-sm">
        {siteConfig.shortName}
      </p>

      <!-- Credentials -->
      <div class="flex items-center gap-3 text-xs text-blue-200">
        <span>CMP {siteConfig.credentials.cmp}</span>
        <span class="w-1 h-1 rounded-full bg-blue-300"></span>
        <span>RNE {siteConfig.credentials.rne}</span>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-4">
        <a
          href={`mailto:${siteConfig.social.email}`}
          class="text-blue-200 hover:text-white transition-colors icon-hover"
          aria-label="Email"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
        </a>
        <a
          href={`https://wa.me/${siteConfig.social.phone.replace(/\+/g, '')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-200 hover:text-white transition-colors icon-hover"
          aria-label="WhatsApp"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492l4.624-1.464A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.813c-2.188 0-4.219-.596-5.975-1.634l-.428-.254-2.742.869.862-2.681-.278-.443A9.777 9.777 0 012.188 12c0-5.414 4.398-9.813 9.812-9.813S21.813 6.586 21.813 12 17.414 21.813 12 21.813z"/></svg>
        </a>
      </div>

      <!-- Divider -->
      <div class="w-full max-w-xs h-px bg-white/10"></div>

      <!-- Copyright -->
      <p class="text-xs text-blue-300/60">
        &copy; {new Date().getFullYear()} {siteConfig.shortName}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
