---
/**
 * ContactCTA — Appointment call-to-action section.
 * Designed for medical patients — trust-building language.
 */
import { siteConfig } from "../config";

const whatsappUrl = `https://wa.me/${siteConfig.cta.phone.replace(/\+/g, '')}?text=${encodeURIComponent('Hola Dr. Robles, me gustaria agendar una consulta.')}`;
---

<section id="contacto" class="py-16 md:py-20 bg-[var(--color-surface)]">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <div class="reveal">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[var(--color-primary-dark)]">
        {siteConfig.cta.title}
      </h2>
      <p class="mt-4 text-gray-600 text-sm md:text-base leading-relaxed max-w-xl mx-auto">
        {siteConfig.cta.description}
      </p>
    </div>

    <!-- CTA buttons -->
    <div class="reveal stagger-2 mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <!-- WhatsApp button -->
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[var(--color-primary)] text-white font-semibold text-sm btn-hover shadow-lg w-full sm:w-auto justify-center"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492l4.624-1.464A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.813c-2.188 0-4.219-.596-5.975-1.634l-.428-.254-2.742.869.862-2.681-.278-.443A9.777 9.777 0 012.188 12c0-5.414 4.398-9.813 9.812-9.813S21.813 6.586 21.813 12 17.414 21.813 12 21.813z"/></svg>
        Contactar por WhatsApp
      </a>

      <!-- Email button -->
      <a
        href={`mailto:${siteConfig.social.email}?subject=${encodeURIComponent(siteConfig.cta.emailSubject)}`}
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white text-[var(--color-primary-dark)] font-semibold text-sm border border-[var(--color-surface)] btn-hover shadow-sm w-full sm:w-auto justify-center"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
        </svg>
        Enviar Email
      </a>
    </div>

    <!-- Contact info -->
    <div class="reveal stagger-3 mt-8 flex flex-col sm:flex-row items-center justify-center gap-6 text-sm text-gray-500">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
        </svg>
        +51 987 001 069
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
        </svg>
        {siteConfig.social.email}
      </span>
    </div>
  </div>
</section>
